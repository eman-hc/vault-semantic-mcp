{
  "name": "vault-semantic-mcp",
  "version": "1.0.0",
  "description": "Local semantic search MCP server for a Markdown vault",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "reindex": "tsx scripts/reindex.ts",
    "test:search": "tsx scripts/test-search.ts"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^4.0.0",
    "gray-matter": "^4.0.3",
    "openai": "^4.0.0",
    "unified": "^11.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
